{
    "name": "psc-acme/parser-billing",
    "description": "Package parser-billing for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ParserBilling\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "league/csv": "^9.0",
        "doctrine/collections": "^2.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "vimeo/psalm": "^5.0",
        "infection/infection": "^0.27"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}